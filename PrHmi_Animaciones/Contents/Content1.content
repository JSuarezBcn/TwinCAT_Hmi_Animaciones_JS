                    "valueType": "tchmi:general#/definitions/Number",
                    "value": 20.0
                  }
                ],
                "asyncWait": true
              }
            ]
          },
          {
            "else": []
          }
        ],
        "asyncWait": true
      },
      {
        "objectType": "Comment",
        "comment": "Temporizacion usando un time trigger de la configuracion del Hmi"
      },
      {
        "objectType": "Function",
        "active": false,
        "fn": "TcHmi.Functions.Beckhoff.StartInterval",
        "fnParams": [
          {
            "objectType": "StaticValue",
            "valueType": "tchmi:framework#/definitions/Interval",
            "value": "cuentaAtras10s"
          }
        ],
        "asyncWait": true
      }
    ]
  }
]
</script>
